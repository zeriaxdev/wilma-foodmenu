{
  "name": "foodmenu",
  "version": "1.2.2",
  "description": "This API provides additional food menus which are not available as JSON as well as unifies other existing food menus into one.\nThis middleware converts them to JSON format.",
  "main": "build/main.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --project ./",
    "production": "tsc --project ./tsconfig.production.json",
    "start": "tsc --project ./ && env-cmd node build/main.js",
    "dev": "tsc --project ./ && env-cmd node --inspect build/main.js",
    "test": "ts-node --project test/tsconfig.json test/endpoints.test.ts",
    "test:jamix": "ts-node --project test/tsconfig.json test/endpoints.test.ts jamix",
    "test:schools": "ts-node --project test/tsconfig.json test/endpoints.test.ts school"
  },
  "keywords": [],
  "author": "",
  "license": "GPL-2.0",
  "repository": "https://github.com/zeriaxdev/wilma-foodmenu",
  "dependencies": {
    "@scalar/express-api-reference": "^0.8.47",
    "body-parser": "^1.19.0",
    "console-stamp": "^3.0.2",
    "express": "^4.18.3",
    "ghostscript-node": "github:developerfromjokela/ghostscript-node",
    "he": "^1.2.0",
    "ical-expander": "^3.1.0",
    "moment": "2.29.4",
    "needle": "^3.3.1",
    "node-fetch": "^2.7.0",
    "node-html-parser": "^6.1.13",
    "node-ts-cache": "^4.2.3",
    "node-ts-cache-storage-memory": "^4.2.3",
    "pdfreader": "^3.0.8",
    "selenium-webdriver": "^4.0.0-beta.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/he": "^1.2.3",
    "@types/needle": "^3.3.0",
    "@types/node": "^22.15.3",
    "@types/node-fetch": "^2.6.12",
    "@types/retry": "^0.12.5",
    "@types/selenium-webdriver": "^4.1.27",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/uuid": "^10.0.0",
    "@types/validator": "^13.12.2",
    "env-cmd": "^10.1.0",
    "swagger-jsdoc": "^6.2.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
